#!/usr/bin/env bash
# Run install/uninstall tests inside a disposable container.
# Requires podman or docker.
set -euo pipefail

RUNTIME="${CONTAINER_RUNTIME:-$(command -v podman 2>/dev/null || command -v docker 2>/dev/null)}"
[ -n "$RUNTIME" ] || { echo "error: no container runtime found" >&2; exit 1; }

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="docker.io/library/perl:5-slim"

echo "Using: $RUNTIME"
echo "Image: $IMAGE"
echo

exec "$RUNTIME" run --rm \
    -v "$REPO_DIR:/repo:ro,z" \
    -e HOME=/home/testuser \
    "$IMAGE" \
    perl -e '
use strict;
use warnings;

my $home = "/home/testuser";
my $repo = "/repo";

my $pass = 0;
my $fail = 0;

sub ok {
    my ($cond, $name) = @_;
    if ($cond) {
        print "  ok    $name\n";
        $pass++;
    } else {
        print "  FAIL  $name\n";
        $fail++;
    }
}

sub heading {
    my ($name) = @_;
    print "\n--- $name ---\n";
}

sub run_install {
    my @args = @_;
    system("perl", "$repo/install", @args) == 0
        or die "install exited with $?\n";
}

sub is_link_to {
    my ($path, $target) = @_;
    return -l $path && readlink($path) eq $target;
}

# expected symlinks after install: [target, source]
my @expect = (
    ["$home/.config/emacs/init.el", "$repo/emacs/init.el"],
    ["$home/.local/bin/em",         "$repo/bin/em"],
    ["$home/.local/bin/em-restart", "$repo/bin/em-restart"],
);
# fonts
my @fonts = glob("$repo/juliamono/*.ttf");
for my $f (@fonts) {
    my ($base) = $f =~ m{/([^/]+)$};
    push @expect, ["$home/.local/share/fonts/$base", $f];
}

my $n = scalar @expect;

# ------------------------------------------------------------------
heading("install on clean home ($n links)");
run_install();

for my $e (@expect) {
    ok(is_link_to($e->[0], $e->[1]), "link $e->[0]");
}

# ------------------------------------------------------------------
heading("install is idempotent");
run_install();

for my $e (@expect) {
    ok(is_link_to($e->[0], $e->[1]), "still $e->[0]");
}

# ------------------------------------------------------------------
heading("uninstall removes all links");
run_install("uninstall");

for my $e (@expect) {
    ok(! -e $e->[0] && ! -l $e->[0], "gone $e->[0]");
}

# ------------------------------------------------------------------
heading("uninstall is idempotent");
run_install("uninstall");

for my $e (@expect) {
    ok(! -e $e->[0] && ! -l $e->[0], "still gone $e->[0]");
}

# ------------------------------------------------------------------
heading("install skips regular files");
# place a regular file where a symlink would go
system("mkdir", "-p", "$home/.local/bin");
open my $fh, ">", "$home/.local/bin/em" or die $!;
print $fh "custom\n";
close $fh;

run_install();

ok(! -l "$home/.local/bin/em",   "em is still a regular file");
ok(-f "$home/.local/bin/em",     "em was not deleted");
# the rest should be linked
ok(is_link_to("$home/.config/emacs/init.el", "$repo/emacs/init.el"),
    "init.el linked despite em conflict");

# cleanup for next test
unlink "$home/.local/bin/em";
run_install("uninstall");

# ------------------------------------------------------------------
heading("uninstall ignores foreign symlinks");
system("mkdir", "-p", "$home/.local/bin");
symlink("/somewhere/else", "$home/.local/bin/em") or die $!;

run_install("uninstall");

ok(-l "$home/.local/bin/em"
    && readlink("$home/.local/bin/em") eq "/somewhere/else",
    "foreign symlink preserved");

unlink "$home/.local/bin/em";

# ------------------------------------------------------------------
heading("install replaces stale symlinks");
system("mkdir", "-p", "$home/.local/bin");
symlink("/old/path", "$home/.local/bin/em") or die $!;

run_install();

ok(is_link_to("$home/.local/bin/em", "$repo/bin/em"),
    "stale symlink replaced");

run_install("uninstall");

# ------------------------------------------------------------------
heading("bad argument rejected");
my $rc = system("perl", "$repo/install", "bogus");
ok($rc != 0, "exits non-zero on bad arg");

# ------------------------------------------------------------------
# summary
print "\n===========================\n";
print "pass: $pass  fail: $fail\n";
print "===========================\n";
exit($fail > 0 ? 1 : 0);
'
